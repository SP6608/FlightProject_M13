@model WebAppFligth.ViewModels.ReservationCreateViewModel

@{
    ViewData["Title"] = "Create Reservation";
}

<h1 class="mb-4">Резервация за полет</h1>

<div class="mb-3">
    <strong>Полет:</strong> @Model.FlightRoute
</div>

<form asp-action="Create" method="post">
    <input asp-for="FlightId" type="hidden" />
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <h4>Пътник 1</h4>

    <div class="mb-3">
        <label asp-for="Passengers[0].FirstName" class="form-label">Име</label>
        <input asp-for="Passengers[0].FirstName" class="form-control" />
        <span asp-validation-for="Passengers[0].FirstName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Passengers[0].MiddleName" class="form-label">Бащино име</label>
        <input asp-for="Passengers[0].MiddleName" class="form-control" />
        <span asp-validation-for="Passengers[0].MiddleName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Passengers[0].LastName" class="form-label">Фамилия</label>
        <input asp-for="Passengers[0].LastName" class="form-control" />
        <span asp-validation-for="Passengers[0].LastName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Passengers[0].Egn" class="form-label">ЕГН</label>
        <input asp-for="Passengers[0].Egn" class="form-control" />
        <span asp-validation-for="Passengers[0].Egn" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Passengers[0].PhoneNumber" class="form-label">Телефон</label>
        <input asp-for="Passengers[0].PhoneNumber" class="form-control" />
        <span asp-validation-for="Passengers[0].PhoneNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Passengers[0].Nationality" class="form-label">Националност</label>
        <input asp-for="Passengers[0].Nationality" class="form-control" />
        <span asp-validation-for="Passengers[0].Nationality" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Passengers[0].TicketType" class="form-label">Тип билет</label>
        <select asp-for="Passengers[0].TicketType"
                asp-items="Html.GetEnumSelectList<WebAppFligth.Models.TicketType>()"
                class="form-select">
        </select>
        <span asp-validation-for="Passengers[0].TicketType" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Запази резервация</button>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}